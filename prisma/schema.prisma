generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String        @id @default(cuid())
  name               String?
  email              String        @unique
  emailVerified      DateTime?     @map("email_verified")
  image              String?
  password           String?
  role               UserRole      @default(CLIENT)
  branch             String?
  isActive           Boolean       @default(true) @map("is_active")
  lastLogin          DateTime?     @map("last_login")
  accessRevokedAt    DateTime?     @map("access_revoked_at")
  accessRevokedBy    String?       @map("access_revoked_by")
  revokeReason       String?       @map("revoke_reason")
  resetToken         String?       @map("reset_token")
  resetTokenExpiry   DateTime?     @map("reset_token_expiry")
  passwordChangedAt  DateTime?     @map("password_changed_at")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")
  accounts           Account[]
  activities         Activity[]
  developmentsEdited Development[] @relation("DevelopmentLastUpdatedBy")
  reservations       Reservation[]
  sessions           Session[]
  passwordHistory    PasswordHistory[]

  // Notification relations
  receivedNotifications Notification[] @relation("ReceivedNotifications")
  actorNotifications    Notification[] @relation("ActorNotifications")

  @@map("users")
}

// Agent model for sales/reservation tracking
model Agent {
  id          String       @id @default(cuid())
  code       String?      @unique @map("agent_code") @db.VarChar(4)
  name       String
  phone      String?      @db.VarChar(20)
  email      String?      @unique @db.VarChar(255)
  status     AgentStatus @default(ACTIVE)
  branch     String?      @db.VarChar(100)
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  // Relations
  reservations Reservation[]
  commissions  Commission[]

  @@index([phone])
  @@index([status])
  @@index([branch])
  @@map("agents")
}

model PasswordHistory {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt(sort: Desc)])
  @@map("password_history")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refreshToken      String? @map("refresh_token")
  accessToken       String? @map("access_token")
  expiresAt         Int?    @map("expires_at")
  tokenType         String? @map("token_type")
  scope             String?
  idToken           String? @map("id_token")
  sessionState      String? @map("session_state")
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Development {
  id                 String           @id @default(cuid())
  name               String
  location           String
  description        String?
  overview           String?
  phase              DevelopmentPhase @default(SERVICING)
  servicingProgress  Decimal          @default(0) @map("servicing_progress") @db.Decimal(5, 2)
  status             String           @default("Active")
  basePrice          Decimal          @map("base_price") @db.Decimal(12, 2)
  pricePerSqm        Decimal?         @map("price_per_sqm") @db.Decimal(10, 2)
  vatPercentage      Decimal          @default(15) @map("vat_percentage") @db.Decimal(5, 2)
  endowmentFee       Decimal          @default(0) @map("endowment_fee") @db.Decimal(10, 2)
  totalAreaSqm       Decimal?         @map("total_area_sqm") @db.Decimal(10, 2)
  totalStands        Int?             @map("total_stands")
  availableStands    Int?             @map("available_stands")
  mainImage          String?          @map("main_image")
  // Map center coordinates (calculated from GeoJSON)
  latitude           Decimal?         @map("latitude") @db.Decimal(10, 6)
  longitude          Decimal?         @map("longitude") @db.Decimal(10, 6)
  gallery            String[]         @map("gallery")
  geoJsonUrl         String?          @map("geo_json_url")
  geoJsonData        Json?            @map("geo_json_data")
  hasGeoJsonMap      Boolean          @default(false) @map("has_geo_json_map")
  disableMapView     Boolean          @default(false) @map("disable_map_view")
  imageUrls          String[]         @map("image_urls")
  logoUrl            String?          @map("logo_url")
  documentUrls       String[]         @map("document_urls")
  termsPdfUrl       String?          @map("terms_pdf_url")
  refundPdfUrl      String?          @map("refund_pdf_url")
  standSizes         Json?            @map("stand_sizes")
  standTypes         String[]         @map("stand_types")
  features           String[]         @default([]) @map("features")
  installmentPeriods Int[]            @default([12, 24, 48]) @map("installment_periods")
  depositPercentage  Decimal          @default(30) @map("deposit_percentage") @db.Decimal(5, 2)
  commissionModel    Json?            @map("commission_model")
  vatEnabled         Boolean          @default(true) @map("vat_enabled")
  endowmentEnabled   Boolean          @default(false) @map("endowment_enabled")
  aosEnabled         Boolean          @default(false) @map("aos_enabled")
  aosFee             Decimal          @default(500) @map("aos_fee") @db.Decimal(10, 2)
  cessionsEnabled    Boolean          @default(false) @map("cessions_enabled")
  cessionFee         Decimal          @default(250) @map("cession_fee") @db.Decimal(10, 2)
  adminFeeEnabled    Boolean          @default(false) @map("admin_fee_enabled")
  adminFee           Decimal          @default(0) @map("admin_fee") @db.Decimal(10, 2)
  featuredTag        String           @default("none") @map("featured_tag")
  developerName      String?          @map("developer_name")
  developerEmail     String?          @map("developer_email")
  developerPhone     String?          @map("developer_phone")
  lawyerName         String?          @map("lawyer_name")
  lawyerEmail        String?          @map("lawyer_email")
  lawyerPhone        String?          @map("lawyer_phone")
  estateProgress     Json?            @map("estate_progress")
  
  // NEW: Service Station Configuration
  hasServiceStation    Boolean          @default(false) @map("has_service_station")
  serviceStationType   String?         @map("service_station_type")
  fuelBrands           String[]         @default([]) @map("fuel_brands")
  serviceStationHoursOpen String?       @map("service_station_hours_open")
  serviceStationHoursClose String?      @map("service_station_hours_close")
  serviceStationIs24Hour Boolean        @default(false) @map("service_station_is_24_hour")
  serviceStationNotes   String?         @map("service_station_notes")
  
  // NEW: Bio Digester Configuration
  hasBioDigester       Boolean          @default(false) @map("has_bio_digester")
  bioDigesterType      String?         @map("bio_digester_type")
  bioDigesterCapacityLiters Int?        @map("bio_digester_capacity_liters")
  bioDigesterInstallDate String?        @map("bio_digester_install_date")
  bioDigesterIsCertified Boolean        @default(false) @map("bio_digester_is_certified")
  bioDigesterIsMunicipalApproved Boolean @default(false) @map("bio_digester_is_municipal_approved")
  bioDigesterIsEPARegistered Boolean    @default(false) @map("bio_digester_is_epa_registered")
  bioDigesterHasMaintenanceContract Boolean @default(false) @map("bio_digester_has_maintenance_contract")
  bioDigesterMaintenanceExpiry String?   @map("bio_digester_maintenance_expiry")
  
  // NEW: Build Compliance Tracking
  buildComplianceStatus String          @default("pending_review") @map("build_compliance_status")
  compliancePlansSubmittedDate String?   @map("compliance_plans_submitted_date")
  complianceEnvironmentalDate String?    @map("compliance_environmental_date")
  complianceWaterSewerageDate String?   @map("compliance_water_sewerage_date")
  complianceElectricalDate String?      @map("compliance_electrical_date")
  complianceFireSafetyDate String?     @map("compliance_fire_safety_date")
  complianceStructuralDate String?      @map("compliance_structural_date")
  complianceApprovalRefNumber String?   @map("compliance_approval_ref_number")
  complianceFinalApprovalDate String?   @map("compliance_final_approval_date")
  
  branch             String           @default("Harare")
  lastUpdatedById    String?          @map("last_updated_by_id")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")
  
  // NEW: Public visibility and ordering fields
  isPublic           Boolean          @default(true) @map("is_public")
  featuredRank       Int?             @map("featured_rank")
  displayRank        Int?             @map("display_rank")
  
  lastUpdatedBy      User?            @relation("DevelopmentLastUpdatedBy", fields: [lastUpdatedById], references: [id], onDelete: SetNull)
  stands             Stand[]
  installmentPlans   InstallmentPlan[]
  contractTemplates  ContractTemplate[]
  clientPurchases    ClientPurchase[]

  @@index([developerEmail])
  @@index([branch])
  @@map("developments")

  // New Ledger Relations
  paymentTransactions PaymentTransaction[]
  sales               Sale[]
}

model Stand {
  id              String        @id @default(cuid())
  standNumber     String        @map("stand_number")
  developmentId   String        @map("development_id")
  branch          String        @default("Harare")
  price           Decimal       @db.Decimal(12, 2)
  pricePerSqm     Decimal?      @map("price_per_sqm") @db.Decimal(10, 2)
  sizeSqm         Decimal?      @map("size_sqm") @db.Decimal(10, 2)
  status          StandStatus   @default(AVAILABLE)
  reservedBy      String?       @map("reserved_by")
  discountPercent Decimal?      @map("discount_percent") @db.Decimal(5, 2)
  discountAmount  Decimal?      @map("discount_amount") @db.Decimal(12, 2)
  discountedPrice Decimal?      @map("discounted_price") @db.Decimal(12, 2)
  discountActive  Boolean       @default(true) @map("discount_active")
  soldAt          DateTime?     @map("sold_at")
  soldReason      String?       @map("sold_reason")
  soldBy          String?       @map("sold_by")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  reservations       Reservation[]
  payments           Payment[]
  installmentPlans   InstallmentPlan[]
  generatedContracts GeneratedContract[]
  offlineSales       OfflineSale[]
  actionLogs         StandActionLog[]
  clientPurchases    ClientPurchase[]
  development        Development   @relation(fields: [developmentId], references: [id], onDelete: Cascade)

  @@unique([developmentId, standNumber])
  @@index([branch])
  @@index([reservedBy])
  @@index([status])
  @@map("stands")

  // New Ledger Relations
  paymentTransactions PaymentTransaction[]
  sales               Sale[]
}

model StandActionLog {
  id          String   @id @default(cuid())
  standId     String   @map("stand_id")
  actionType  String   @map("action_type")
  payload     Json?
  reason      String
  oldValues   Json?    @map("old_values")
  newValues   Json?    @map("new_values")
  createdBy   String   @map("created_by")
  createdByEmail String? @map("created_by_email")
  createdAt   DateTime @default(now()) @map("created_at")
  stand       Stand    @relation(fields: [standId], references: [id], onDelete: Cascade)

  @@index([standId])
  @@index([actionType])
  @@index([createdAt])
  @@map("stand_action_logs")
}

model Reservation {
  id               String            @id @default(cuid())
  standId          String            @map("stand_id")
  userId           String?           @map("user_id")
  agentId          String?           @map("agent_id")
  isCompanyLead    Boolean           @default(false) @map("is_company_lead")
  assignedLeadType String?           @map("assigned_lead_type")
  termsAcceptedAt  DateTime          @map("terms_accepted_at")
  expiresAt        DateTime          @map("expires_at")
  status           ReservationStatus @default(PENDING)
  timerActive      Boolean           @default(true) @map("timer_active")
  popUrl           String?           @map("pop_url")
  basePriceAtReservation Decimal?    @map("base_price_at_reservation") @db.Decimal(12, 2)
  discountPercentAtReservation Decimal? @map("discount_percent_at_reservation") @db.Decimal(5, 2)
  finalPriceAtReservation Decimal?   @map("final_price_at_reservation") @db.Decimal(12, 2)
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  clientId         String?
  agent            Agent?            @relation(fields: [agentId], references: [id])
  client           Client?           @relation(fields: [clientId], references: [id])
  stand            Stand             @relation(fields: [standId], references: [id], onDelete: Cascade)
  user             User?             @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([standId])
  @@index([userId])
  @@index([agentId])
  @@index([expiresAt])
  @@map("reservations")
}

model Activity {
  id          String       @id @default(cuid())
  type        ActivityType
  description String
  metadata    Json?
  userId      String       @map("user_id")
  createdAt   DateTime     @default(now()) @map("created_at")
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([createdAt(sort: Desc)])
  @@map("activities")
}

/// *
///  * Invitation
///  * Email invitations for new users
///  * Tracks invitation lifecycle and tokens
model Invitation {
  id         String           @id @default(cuid())
  email      String
  fullName   String?          @map("full_name")
  role       UserRole
  branch     String
  token      String           @unique
  status     InvitationStatus @default(PENDING)
  invitedBy  String           @map("invited_by")
  expiresAt  DateTime         @map("expires_at")
  acceptedAt DateTime?        @map("accepted_at")
  revokedAt  DateTime?        @map("revoked_at")
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")
  
  // Email tracking fields
  emailSentAt       DateTime? @map("email_sent_at")
  emailFailedAt     DateTime? @map("email_failed_at")
  emailFailureReason String?  @map("email_failure_reason")
  emailAttempts     Int       @default(0) @map("email_attempts")
  lastEmailAttempt  DateTime? @map("last_email_attempt")

  @@index([email])
  @@index([token])
  @@index([status])
  @@index([invitedBy])
  @@map("invitations")
}

/// *
///  * Audit Trail
///  * Comprehensive audit logging for all system actions
///  * Tracks user actions, resource changes, and compliance events
model AuditTrail {
  id           String   @id @default(cuid())
  action       String
  resourceType String   @map("resource_type")
  resourceId   String   @map("resource_id")
  userId       String?  @map("user_id")
  details      Json?
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  branch       String?
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([action])
  @@index([resourceType, resourceId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_trails")
}

model DevelopmentEdit {
  id            String   @id @default(cuid())
  developmentId String   @map("development_id")
  fieldName     String   @map("field_name")
  oldValue      String?  @map("old_value")
  newValue      String?  @map("new_value")
  editedBy      String   @map("edited_by")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([developmentId])
  @@index([createdAt(sort: Desc)])
  @@map("development_edits")
}

model Client {
  id               String            @id @default(cuid())
  name             String
  firstName        String?           @map("first_name")
  lastName         String?           @map("last_name")
  email            String
  phone            String?
  nationalId       String?           @map("national_id")
  branch           String            @default("Harare")
  isPortalUser     Boolean           @default(false) @map("is_portal_user")
  kyc              Json[]            @default([])
  ownedStands      String[]          @map("owned_stands")
  budget           Decimal?          @map("budget") @db.Decimal(12, 2)
  lookingFor       String?           @map("looking_for")
  preferences      Json?             @map("preferences")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  agentId          String?           @map("agent_id")
  isProspect       Boolean           @default(false) @map("is_prospect")
  reservations     Reservation[]
  payments         Payment[]
  installmentPlans InstallmentPlan[]
  generatedContracts GeneratedContract[]
  offlineSales     OfflineSale[]
  purchases        ClientPurchase[]

  @@unique([email, branch])
  @@index([branch])
  @@index([agentId])
  @@map("clients")

  // New Ledger Relations
  paymentTransactions PaymentTransaction[]
  sales               Sale[]
}

// ═══════════════════════════════════════════════════════════════════════════
// CLIENT PURCHASE MODULE - Links Client ↔ Development ↔ Stand
// One stand cannot have two active purchases
// ═══════════════════════════════════════════════════════════════════════════

model ClientPurchase {
  id              String          @id @default(cuid())
  clientId        String          @map("client_id")
  developmentId   String          @map("development_id")
  standId         String          @map("stand_id")
  purchasePrice   Decimal         @map("purchase_price") @db.Decimal(12, 2)
  depositAmount   Decimal         @default(0) @map("deposit_amount") @db.Decimal(12, 2)
  periodMonths    Int             @default(12) @map("period_months")
  monthlyAmount   Decimal         @default(0) @map("monthly_amount") @db.Decimal(12, 2)
  startDate       DateTime        @map("start_date")
  status          PurchaseStatus  @default(ACTIVE)
  notes           String?
  branch          String          @default("Harare")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  // Relations
  client          Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  development     Development     @relation(fields: [developmentId], references: [id], onDelete: Cascade)
  stand           Stand           @relation(fields: [standId], references: [id], onDelete: Cascade)
  purchasePayments PurchasePayment[]

  // One stand cannot have two active purchases (enforced via unique partial index in migration)
  @@index([clientId])
  @@index([developmentId])
  @@index([standId])
  @@index([status])
  @@index([branch])
  @@map("client_purchases")
}

model PurchasePayment {
  id                String          @id @default(cuid())
  clientPurchaseId  String          @map("client_purchase_id")
  amount            Decimal         @db.Decimal(12, 2)
  paymentDate       DateTime        @map("payment_date")
  method            String          @default("CASH")
  reference         String?
  description       String?
  receiptNo         String?         @unique @map("receipt_no")
  status            String          @default("CONFIRMED")
  createdBy         String?         @map("created_by")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  // Relations
  clientPurchase    ClientPurchase  @relation(fields: [clientPurchaseId], references: [id], onDelete: Cascade)

  @@index([clientPurchaseId])
  @@index([paymentDate])
  @@index([status])
  @@map("purchase_payments")
}

enum PurchaseStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  SUSPENDED
}

// ═══════════════════════════════════════════════════════════════════════════
// DEPRECATED: Legacy Payment table - DO NOT WRITE TO THIS TABLE
// All new payments must use PaymentTransaction (the canonical ledger)
// This table is kept for backward compatibility and historical data
// ═══════════════════════════════════════════════════════════════════════════
model Payment {
  id                  String    @id @default(cuid())
  clientId            String    @map("client_id")
  clientName          String    @map("client_name")
  amount              Decimal   @db.Decimal(12, 2)
  surchargeAmount     Decimal   @default(0) @map("surcharge_amount") @db.Decimal(12, 2)
  standId             String?   @map("stand_id")
  description         String    @default("Payment")
  status              String    @default("PENDING")
  method              String
  paymentType         String    @map("payment_type")
  officeLocation      String    @map("office_location")
  reference           String    @unique
  confirmedAt         DateTime? @map("confirmed_at")
  receivedByName      String?   @map("received_by_name")
  manualReceiptNo     String    @map("manual_receipt_no")
  verificationStatus  String    @default("Pending") @map("verification_status")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  installmentId       String?   @map("installment_id")
  aosAmount           Decimal?  @map("aos_amount") @db.Decimal(12, 2)
  cessionAmount       Decimal?  @map("cession_amount") @db.Decimal(12, 2)
  developmentId       String?   @map("development_id")
  endowmentAmount     Decimal?  @map("endowment_amount") @db.Decimal(12, 2)
  feeCalculation      Json?     @map("fee_calculation")
  settlementStatus    String?   @default("PENDING") @map("settlement_status")
  standPricePortion   Decimal?  @map("stand_price_portion") @db.Decimal(12, 2)
  vatAmount           Decimal?  @map("vat_amount") @db.Decimal(12, 2)

  // Relations
  client              Client?   @relation(fields: [clientId], references: [id])
  stand               Stand?    @relation(fields: [standId], references: [id])
  receipt             Receipt?
  allocations         PaymentAllocation[]

  @@index([officeLocation])
  @@index([clientId])
  @@index([status])
  @@index([paymentType])
  @@index([installmentId])
  @@index([settlementStatus])
  @@index([developmentId])
  @@index([standId], map: "idx_payments_stand_id")
  @@map("payments")
}

// ═══════════════════════════════════════════════════════════════════════════
// DEPRECATED: Legacy InstallmentPlan - DO NOT CREATE NEW PLANS
// Use Sale + Invoice + PaymentTransaction for new transactions
// ═══════════════════════════════════════════════════════════════════════════
model InstallmentPlan {
  id               String    @id @default(cuid())
  clientId         String    @map("client_id")
  standId          String    @map("stand_id")
  developmentId    String    @map("development_id")
  totalAmount      Decimal   @map("total_amount") @db.Decimal(12, 2)
  depositAmount    Decimal   @map("deposit_amount") @db.Decimal(12, 2)
  depositPaid      Boolean   @default(false) @map("deposit_paid")
  balanceAmount    Decimal   @map("balance_amount") @db.Decimal(12, 2)
  periodMonths     Int       @map("period_months")
  monthlyAmount    Decimal   @map("monthly_amount") @db.Decimal(12, 2)
  totalPaid        Decimal   @default(0) @map("total_paid") @db.Decimal(12, 2)
  remainingBalance Decimal   @map("remaining_balance") @db.Decimal(12, 2)
  paidInstallments Int       @default(0) @map("paid_installments")
  nextDueDate      DateTime? @map("next_due_date")
  status           String    @default("ACTIVE")
  startDate        DateTime  @map("start_date")
  endDate          DateTime  @map("end_date")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  // Relations
  client           Client      @relation(fields: [clientId], references: [id])
  stand            Stand       @relation(fields: [standId], references: [id])
  development      Development @relation(fields: [developmentId], references: [id])
  installments     Installment[]
  allocations      PaymentAllocation[]

  @@index([clientId])
  @@index([developmentId])
  @@index([status])
  @@map("installment_plans")
}

model Installment {
  id            String    @id @default(cuid())
  planId        String    @map("plan_id")
  installmentNo Int       @map("installment_no")
  amountDue     Decimal   @map("amount_due") @db.Decimal(12, 2)
  amountPaid    Decimal   @default(0) @map("amount_paid") @db.Decimal(12, 2)
  dueDate       DateTime  @map("due_date")
  paidDate      DateTime? @map("paid_date")
  status        String    @default("PENDING")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  plan          InstallmentPlan @relation(fields: [planId], references: [id])
  receipt       Receipt?
  allocations   PaymentAllocation[]

  @@index([planId])
  @@index([dueDate])
  @@index([status])
  @@map("installments")
}

model Receipt {
  id              String    @id @default(cuid())
  receiptNumber   String    @unique @map("receipt_number")
  paymentId       String?   @unique @map("payment_id")
