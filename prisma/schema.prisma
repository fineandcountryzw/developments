model PaymentTransaction {
  id              String   @id @default(cuid())
  postedAt        DateTime @map("posted_at")
  amount          Decimal  @db.Decimal(12, 2)
  currency        Currency @default(USD)
  method          PaymentMethod
  reference       String?
  externalId      String?  @map("external_id")
  idempotencyKey  String   @unique @map("idempotency_key")
  memo            String?
  
  // Linkage
  clientId        String   @map("client_id")
  saleId          String?  @map("sale_id")
  invoiceId       String?  @map("invoice_id")
  developmentId   String?  @map("development_id")
  standId         String?  @map("stand_id")
  
  source          PaymentSource @default(MANUAL)
  status          TransactionStatus @default(COMPLETED)
  
  createdByUserId String?  @map("created_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  client          Client      @relation(fields: [clientId], references: [id])
  sale            Sale?       @relation(fields: [saleId], references: [id])
  invoice         Invoice?    @relation(fields: [invoiceId], references: [id])
  development     Development? @relation(fields: [developmentId], references: [id])
  stand           Stand?      @relation(fields: [standId], references: [id])
  allocations     LedgerAllocation[]

  @@index([clientId, postedAt])
  @@index([saleId, postedAt])
  @@index([invoiceId, postedAt])
  @@index([developmentId])
  @@index([standId])
  @@map("payment_transactions")
}

model Sale {
  id              String   @id @default(cuid())
  clientId        String   @map("client_id")
  developmentId   String   @map("development_id")
  standId         String?  @map("stand_id")
  
  saleType        SaleType
  currency        Currency @default(USD)
  
  principalAmount Decimal  @map("principal_amount") @db.Decimal(12, 2)
  vatAmount       Decimal? @map("vat_amount") @db.Decimal(12, 2)
  adminFees       Decimal? @map("admin_fees") @db.Decimal(12, 2)
  totalAmount     Decimal  @map("total_amount") @db.Decimal(12, 2)
  
  status          SaleStatus @default(DRAFT)
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  client          Client      @relation(fields: [clientId], references: [id])
  development     Development @relation(fields: [developmentId], references: [id])
  stand           Stand?      @relation(fields: [standId], references: [id])
  invoices        Invoice[]
  payments        PaymentTransaction[]

  @@index([clientId])
  @@index([developmentId])
  @@index([standId])
  @@map("sales")
}

model LedgerAllocation {
  id                   String   @id @default(cuid())
  paymentTransactionId String   @map("payment_transaction_id")
  invoiceId            String   @map("invoice_id")
  amount               Decimal  @db.Decimal(12, 2)
  
  createdAt            DateTime @default(now()) @map("created_at")

  paymentTransaction   PaymentTransaction @relation(fields: [paymentTransactionId], references: [id])
  invoice              Invoice            @relation(fields: [invoiceId], references: [id])

  @@index([paymentTransactionId])
  @@index([invoiceId])
  @@map("ledger_allocations")
}

enum Currency {
