///  * Enables fine-grained access control beyond simple role checks
model AccessControl {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  resource  String
  action    String
  branch    String    @default("Harare")
  grantedBy String?   @map("granted_by")
  grantedAt DateTime  @default(now()) @map("granted_at")
  expiresAt DateTime? @map("expires_at")

  @@unique([userId, resource, action, branch])
  @@index([userId])
  @@index([resource])
  @@index([branch])
  @@map("access_controls")
}

/// *
///  * Compliance Checklist
///  * Track compliance requirements and certifications
model ComplianceCheck {
  id         String    @id @default(cuid())
  recordId   String    @map("record_id")
  recordType String    @map("record_type")
  checkType  String    @map("check_type")
  status     String    @default("PENDING")
  branch     String    @default("Harare")
  checkedBy  String?   @map("checked_by")
  checkedAt  DateTime? @map("checked_at")
  notes      String?
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@index([recordId])
  @@index([recordType])
  @@index([status])
  @@index([branch])
  @@map("compliance_checks")
}

/// *
///  * Data Retention Policy
///  * Defines how long different types of data are retained
model DataRetentionPolicy {
  id            String   @id @default(cuid())
  dataType      String   @unique @map("data_type")
  retentionDays Int      @map("retention_days")
  archiveAfter  Boolean  @default(false) @map("archive_after")
  deleteAfter   Boolean  @default(false) @map("delete_after")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("data_retention_policies")
}

/// *
///  * Unsubscribe List
///  * Tracks recipients who have unsubscribed, bounced hard, or marked as spam
///  * Used to suppress future sends to these addresses (GDPR/CAN-SPAM compliant)
model UnsubscribeList {
  id                   String    @id @default(cuid())
  recipientEmail       String    @map("recipient_email")
  clientId             String    @map("client_id")
  reason               String
  description          String?
  unsubscribedAt       DateTime  @map("unsubscribed_at")
  resubscribeAttemptAt DateTime? @map("resubscribe_attempt_at")
  unsubscribedBy       String?   @map("unsubscribed_by")
  branch               String    @default("Harare")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  @@unique([recipientEmail, clientId])
  @@index([recipientEmail])
  @@index([clientId])
  @@index([reason])
  @@index([unsubscribedAt])
  @@index([branch])
  @@map("unsubscribe_lists")
}

/// *
///  * Bounce Pattern
///  * Tracks bounce history and determines if recipient should be suppressed
///  * Categorizes bounces as soft (temporary) or hard (permanent)
model BouncePattern {
  id                 String    @id @default(cuid())
  recipientEmail     String    @map("recipient_email")
  clientId           String    @map("client_id")
  bounceType         String
  lastBounceAt       DateTime  @map("last_bounce_at")
  consecutiveBounces Int       @default(1) @map("consecutive_bounces")
  totalBounceCount   Int       @default(1) @map("total_bounce_count")
  bounceReason       String?   @map("bounce_reason")
  smtpCode           String?   @map("smtp_code")
  shouldSuppress     Boolean   @default(false) @map("should_suppress")
  suppressedAt       DateTime? @map("suppressed_at")
  suppressedReason   String?   @map("suppressed_reason")
  branch             String    @default("Harare")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@unique([recipientEmail, clientId])
  @@index([recipientEmail])
  @@index([clientId])
  @@index([bounceType])
  @@index([shouldSuppress])
  @@index([lastBounceAt])
  @@index([branch])
  @@map("bounce_patterns")
}

/// *
///  * Email Engagement Score
///  * Calculates recipient engagement on 0-100 scale
///  * Predicts payment probability based on email engagement patterns
model EmailEngagementScore {
  id                          String    @id @default(cuid())
  recipientEmail              String    @map("recipient_email")
  clientId                    String    @map("client_id")
  clientName                  String?   @map("client_name")
  engagementScore             Float     @default(0) @map("engagement_score")
  engagementTier              String    @default("cold") @map("engagement_tier")
  openCount                   Int       @default(0) @map("open_count")
  clickCount                  Int       @default(0) @map("click_count")
  bounceCount                 Int       @default(0) @map("bounce_count")
  unsubscribeCount            Int       @default(0) @map("unsubscribe_count")
  totalEmailsSent             Int       @default(0) @map("total_emails_sent")
  uniqueEmailsSent            Int       @default(0) @map("unique_emails_sent")
  lastEngagementAt            DateTime? @map("last_engagement_at")
  lastOpenAt                  DateTime? @map("last_open_at")
  lastClickAt                 DateTime? @map("last_click_at")
  predictedPaymentProbability Float     @default(0) @map("predicted_payment_probability")
  paymentHistoryDaysAgo       Int?      @map("payment_history_days_ago")
  branch                      String    @default("Harare")
  createdAt                   DateTime  @default(now()) @map("created_at")
  updatedAt                   DateTime  @updatedAt @map("updated_at")

  @@unique([recipientEmail, clientId])
  @@index([recipientEmail])
  @@index([clientId])
  @@index([engagementScore])
  @@index([engagementTier])
  @@index([predictedPaymentProbability])
  @@index([lastEngagementAt])
  @@index([branch])
  @@map("email_engagement_scores")
}

/// *
///  * Campaign Performance
///  * Tracks ROI and effectiveness of each campaign type
///  * Compares Reminder vs Escalation vs Follow-up performance
model CampaignPerformance {
  id                    String   @id @default(cuid())
  campaignType          String   @map("campaign_type")
  dateRange             DateTime @map("date_range")
  branch                String   @default("Harare")
  sentCount             Int      @default(0) @map("sent_count")
  deliveredCount        Int      @default(0) @map("delivered_count")
  openCount             Int      @default(0) @map("open_count")
  clickCount            Int      @default(0) @map("click_count")
  bounceCount           Int      @default(0) @map("bounce_count")
  unsubscribeCount      Int      @default(0) @map("unsubscribe_count")
  conversionCount       Int      @default(0) @map("conversion_count")
  conversion30DayCount  Int      @default(0) @map("conversion_30day_count")
  totalRevenueGenerated Decimal  @default(0) @map("total_revenue_generated") @db.Decimal(12, 2)
  campaignCost          Decimal  @default(0) @map("campaign_cost") @db.Decimal(12, 2)
  roi                   Float    @default(0) @map("roi")
  openRate              Float    @default(0) @map("open_rate")
  clickRate             Float    @default(0) @map("click_rate")
  bounceRate            Float    @default(0) @map("bounce_rate")
  conversionRate        Float    @default(0) @map("conversion_rate")
  lastRefreshedAt       DateTime @default(now()) @updatedAt @map("last_refreshed_at")
  createdAt             DateTime @default(now()) @map("created_at")

  @@unique([campaignType, dateRange, branch])
  @@index([campaignType])
  @@index([dateRange])
  @@index([branch])
  @@index([roi])
  @@index([conversionRate])
  @@map("campaign_performances")
}

/// *
///  * Send Time Optimization
///  * Tracks best send times per recipient for maximum open rates
///  * Uses data-driven analysis to determine optimal send window
model SendTimeOptimization {
  id                String   @id @default(cuid())
  recipientEmail    String   @map("recipient_email")
  clientId          String   @map("client_id")
  clientName        String?  @map("client_name")
  bestSendHour      Int?     @map("best_send_hour")
  bestSendDayOfWeek Int?     @map("best_send_day_of_week")
  openRateByHour    String   @map("open_rate_by_hour")
  openRateByDay     String   @map("open_rate_by_day")
  totalOpens        Int      @default(0) @map("total_opens")
  totalSends        Int      @default(0) @map("total_sends")
  sampleSize        Int      @default(0) @map("sample_size")
  confidence        Float    @default(0) @map("confidence")
  lastUpdatedAt     DateTime @default(now()) @updatedAt @map("last_updated_at")
  branch            String   @default("Harare")
  createdAt         DateTime @default(now()) @map("created_at")

  @@unique([recipientEmail, clientId])
  @@index([recipientEmail])
  @@index([clientId])
  @@index([bestSendHour])
  @@index([bestSendDayOfWeek])
  @@index([confidence])
  @@index([branch])
  @@map("send_time_optimizations")
}

/// *
///  * Kanban Board
///  * Main container for pipeline management
///  * Supports custom stages, deals, rules, and collaboration
model KanbanBoard {
  id          String   @id @default(cuid())
  name        String
  description String?
  branchId    String?
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([branchId])
  @@index([isArchived])
  @@map("kanban_boards")
}

/// *
///  * Stage
///  * Pipeline stages (Lead, Negotiation, Proposal, Closing, etc.)
///  * Supports WIP limits and custom colors
model Stage {
  id          String   @id @default(cuid())
  boardId     String
  name        String
  description String?
  color       String   @default("#3b82f6")
  orderIndex  Int
  wipLimit    Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([boardId])
  @@index([orderIndex])
  @@map("stages")
}

/// *
///  * Deal
///  * Individual sales opportunities tracked through pipeline
///  * Includes intelligent metrics and collaboration features
model Deal {
  id                String    @id @default(cuid())
  boardId           String
  stageId           String
  clientId          String
  ownerId           String
  title             String
  description       String?
  value             Decimal   @db.Decimal(12, 2)
  probability       Float     @default(50)
  expectedCloseDate DateTime?
  healthScore       Int?
  riskLevel         String?
  winProbability    Float?
  customValues      Json?
  isArchived        Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  standId           String?   @unique @map("stand_id")

  @@index([boardId])
  @@index([stageId])
  @@index([clientId])
  @@index([ownerId])
  @@index([probability])
  @@index([healthScore])
  @@index([riskLevel])
  @@index([isArchived])
  @@index([standId])
  @@map("deals")
}

/// *
///  * Pipeline Rule
///  * Automated actions based on deal conditions
///  * Rules trigger notifications, moves, assignments, escalations
model PipelineRule {
  id            String    @id @default(cuid())
  boardId       String
  name          String
  description   String?
  condition     Json
  action        Json
  enabled       Boolean   @default(true)
  lastTriggered DateTime?
  triggerCount  Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([boardId])
  @@index([enabled])
  @@index([lastTriggered])
  @@map("pipeline_rules")
}

/// *
///  * Custom Field
///  * Board-level custom fields for deal tracking
///  * Supports text, number, date, select, multiselect types
model CustomField {
  id         String   @id @default(cuid())
  boardId    String
  name       String
  type       String
  options    String[] @default([])
  required   Boolean  @default(false)
  orderIndex Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([boardId])
  @@map("custom_fields")
}

/// *
///  * Deal Activity
///  * Audit trail for deal changes
///  * Tracks all modifications, moves, comments
model DealActivity {
  id        String   @id @default(cuid())
  dealId    String
  userId    String
  type      String
  changes   Json?
  createdAt DateTime @default(now())

  @@index([dealId])
  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@map("deal_activities")
}

/// *
///  * Comment
///  * Deal collaboration and discussion
///  * Supports @mentions and file attachments
model Comment {
  id          String   @id @default(cuid())
  dealId      String
  userId      String
  content     String
  attachments String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([dealId])
  @@index([userId])
  @@index([createdAt])
  @@map("comments")
}

/// *
///  * Template Version
///  * Version history for contract templates
///  * Track changes and allow rollback
model ContractTemplateVersion {
  id                 String   @id @default(cuid())
  templateId         String   @map("template_id")
  version            Int
  content            String
  htmlContent        String?  @map("html_content")
  
  // DOCX Template Support
  templateType       String   @default("html") @map("template_type")
  templateFileUrl    String?  @map("template_file_url")
  templateFileKey    String?  @map("template_file_key")
  templateVariables  Json     @default("[]") @map("template_variables")
  
  variables          Json     @default("[]")
  changedBy          String?  @map("changed_by")
  changeNotes        String?  @map("change_notes")
  createdAt          DateTime @default(now()) @map("created_at")

  // Relations
  template ContractTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@index([version])
  @@unique([templateId, version])
  @@map("contract_template_versions")
}

/// *
///  * Template Variable
///  * Variable definitions within a template
///  * Supports text, number, date, select types
model TemplateVariable {
  id           String   @id @default(cuid())
  templateId   String   @map("template_id")
  name         String
  placeholder  String
  dataType     String   @map("data_type")
  required     Boolean  @default(false)
  defaultValue String?  @map("default_value")
  options      String[] @default([])
  mappedField  String?  @map("mapped_field")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([templateId])
  @@map("template_variables")
}

/// *
///  * Template Section
///  * Content sections within a template
///  * Supports conditional rendering
model TemplateSection {
  id          String   @id @default(cuid())
  templateId  String   @map("template_id")
  name        String
  content     String
  orderIndex  Int      @map("order_index")
  conditional String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([templateId])
  @@index([orderIndex])
  @@map("template_sections")
}

/// *
///  * Contract
///  * Generated contract instances from templates
///  * Tracks status, signatures, and lifecycle
model Contract {
  id                 String    @id @default(cuid())
  templateId         String    @map("template_id")
  dealId             String?   @map("deal_id")
  clientId           String    @map("client_id")
  title              String
  content            String
  status             String    @default("draft")
  startDate          DateTime? @map("start_date")
  endDate            DateTime? @map("end_date")
  renewalDate        DateTime? @map("renewal_date")
  requiredSignatures Int       @default(1) @map("required_signatures")
  signedCount        Int       @default(0) @map("signed_count")
  variables          Json?
  branch             String    @default("Harare")
  createdBy          String?   @map("created_by")
  pdfUrl             String?   @map("pdf_url")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  // DocuSeal E-Signature Integration Fields
  docusealSubmissionId       Int?      @map("docuseal_submission_id")
  docusealStatus             String?   @map("docuseal_status")
  docusealSignerClientId     Int?      @map("docuseal_signer_client_id")
  docusealSignerClientStatus String?   @map("docuseal_signer_client_status")
  docusealSignerDevId        Int?      @map("docuseal_signer_dev_id")
  docusealSignerDevStatus    String?   @map("docuseal_signer_dev_status")
  signedPdfUrl               String?   @map("signed_pdf_url")
  sentForSignatureAt         DateTime? @map("sent_for_signature_at")
  fullySignedAt              DateTime? @map("fully_signed_at")
  developerEmail             String?   @map("developer_email")
  developerName              String?   @map("developer_name")

  @@index([clientId])
  @@index([status])
  @@index([dealId])
  @@index([branch])
  @@index([signedCount])
  @@index([createdAt])
  @@index([docusealSubmissionId])
  @@map("contracts")
}

/// *
///  * Contract Signature
///  * Signature requests and tracking
///  * Handles multiple signers with roles
model ContractSignature {
  id             String    @id @default(cuid())
  contractId     String    @map("contract_id")
  signerName     String    @map("signer_name")
  signerEmail    String    @map("signer_email")
  signerRole     String    @map("signer_role")
  signatureData  String?   @map("signature_data")
  ipAddress      String?   @map("ip_address")
  userAgent      String?   @map("user_agent")
  status         String    @default("pending")
  sentAt         DateTime? @map("sent_at")
  signedAt       DateTime? @map("signed_at")
  expiresAt      DateTime? @map("expires_at")
  reminderSentAt DateTime? @map("reminder_sent_at")
  signedByUserId String?   @map("signed_by_user_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([contractId])
  @@index([status])
  @@index([signerEmail])
  @@index([signedAt])
  @@map("contract_signatures")
}

/// *
///  * Contract Version
///  * Version history for contracts
///  * Track amendments and changes
model ContractVersion {
  id            String   @id @default(cuid())
  contractId    String   @map("contract_id")
  versionNumber Int      @map("version_number")
  content       String
  changes       Json?
  changeNotes   String?  @map("change_notes")
  changedBy     String?  @map("changed_by")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([contractId])
  @@index([versionNumber])
  @@map("contract_versions")
}

/// *
///  * Contract Amendment
///  * Tracked amendments to contracts
///  * Maintains change history and approval workflow
model ContractAmendment {
  id          String   @id @default(cuid())
  contractId  String   @map("contract_id")
  title       String
  description String?
  changes     Json
  status      String   @default("draft")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([contractId])
  @@index([status])
  @@map("contract_amendments")
}

/// *
///  * Contract Activity
///  * Audit trail for contract actions
///  * Tracks all modifications and workflow changes
model ContractActivity {
  id            String   @id @default(cuid())
  contractId    String   @map("contract_id")
  action        String
  actorId       String?  @map("actor_id")
  actorEmail    String?  @map("actor_email")
  actorRole     String?  @map("actor_role")
  details       Json?
  changesBefore Json?    @map("changes_before")
  changesAfter  Json?    @map("changes_after")
  ipAddress     String?  @map("ip_address")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([contractId])
  @@index([action])
  @@index([createdAt])
  @@map("contract_activities")
}

/// *
///  * Company Settings
///  * Stores branch-specific settings like logo, contact info
///  * Persists to database so visible across all browsers/sessions
model CompanySettings {
  id           String   @id @default(cuid())
  branch       String   @unique
  logo_url     String?  @map("logo_url")
  company_name String?  @default("Fine & Country Zimbabwe") @map("company_name")
  phone        String?  @map("phone")
  email        String?  @map("email")
  address      String?  @map("address")
  principalAgentName  String? @map("principal_agent_name")
  principalAgentEmail String? @map("principal_agent_email")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([branch])
  @@map("company_settings")
}

/// Signers for a GeneratedContract (DocuSeal + internal tracking)
/// Keeps signer roles/statuses normalized so we can support 4+ signatories.
model GeneratedContractSigner {
  id             String   @id @default(cuid())
  contractId     String   @map("contract_id")
  role           String   @map("role") // e.g. client, developer, lawyer, principal_agent
  name           String?  @map("name")
  email          String   @map("email")
  status         String   @default("not_invited") @map("status") // not_invited|pending|opened|signed|declined|expired
  docusealSignerId Int?   @map("docuseal_signer_id")
  invitedAt      DateTime? @map("invited_at")
  openedAt       DateTime? @map("opened_at")
  signedAt       DateTime? @map("signed_at")
  declinedAt     DateTime? @map("declined_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  contract GeneratedContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@unique([contractId, role])
  @@index([contractId])
  @@index([email])
  @@index([status])
  @@map("generated_contract_signers")
}

/// *
///  * Automation
///  * Unified automation system using Trigger → Condition → Action model
///  * Replaces PaymentAutomationSettings and PipelineRule
model Automation {
  id           String          @id @default(cuid())
  name         String
  description  String?
  enabled      Boolean         @default(true)
  triggerType  String          @map("trigger_type")
  eventType    String?         @map("event_type")
  schedule     String?
  webhookUrl   String?         @map("webhook_url")
  entityType   String          @map("entity_type")
  condition    Json?
  actions      Json
  branch       String          @default("Harare")
  retryPolicy  Json?           @map("retry_policy")
  lastRunAt    DateTime?       @map("last_run_at")
  runCount     Int             @default(0) @map("run_count")
  successCount Int             @default(0) @map("success_count")
  failureCount Int             @default(0) @map("failure_count")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  runs         AutomationRun[]

  @@index([enabled])
  @@index([triggerType, eventType])
  @@index([branch])
  @@map("automations")
}

/// *
///  * AutomationRun
///  * Tracks every automation execution for observability and retry
model AutomationRun {
  id             String     @id @default(cuid())
  automationId   String     @map("automation_id")
  eventType      String     @map("event_type")
  entityType     String     @map("entity_type")
  entityId       String     @map("entity_id")
  correlationId  String?    @map("correlation_id")
  status         String
  actionType     String     @map("action_type")
  actionTarget   String     @map("action_target")
  idempotencyKey String     @unique @map("idempotency_key")
  retryCount     Int        @default(0) @map("retry_count")
  maxRetries     Int        @default(3) @map("max_retries")
  result         Json?
  errorMessage   String?    @map("error_message")
  errorStack     String?    @map("error_stack")
  scheduledAt    DateTime?  @map("scheduled_at")
  startedAt      DateTime?  @map("started_at")
  completedAt    DateTime?  @map("completed_at")
  durationMs     Int?       @map("duration_ms")
  branch         String     @default("Harare")
  createdAt      DateTime   @default(now()) @map("created_at")
  automation     Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  @@index([automationId])
  @@index([entityId])
  @@index([correlationId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("automation_runs")
}

/// *
///  * AutomationEventLog
///  * Logs all events emitted for observability and event replay
model AutomationEventLog {
  id                   String   @id @default(cuid())
  eventType            String   @map("event_type")
  entityType           String   @map("entity_type")
  entityId             String   @map("entity_id")
  payload              Json
  branch               String   @default("Harare")
  triggeredAutomations String[] @map("triggered_automations")
  timestamp            DateTime @default(now())

  @@index([eventType])
  @@index([entityId])
  @@index([timestamp(sort: Desc)])
  @@map("automation_event_logs")
}

model SalesTarget {
  id            String   @id @default(cuid())
  agentId       String   @map("agent_id")
  developmentId String?  @map("development_id")
  branch        String   @default("Harare")
  targetPeriod  String   @map("target_period")
  targetType    String   @default("MONTHLY") @map("target_type")
  revenueTarget Decimal? @map("revenue_target") @db.Decimal(12, 2)
  dealsTarget   Int?     @map("deals_target")
  setBy         String   @map("set_by")
  notes         String?
  status        String   @default("ACTIVE")
