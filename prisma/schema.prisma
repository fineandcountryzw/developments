/// *
///  * Task Manager
///  * Personal task management with notes for agents and users
model Task {
  id          String      @id @default(cuid())
  title       String
  description String?
  notes       String?     @map("notes")
  status      TaskStatus  @default(PENDING)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?   @map("due_date")
  completedAt DateTime?   @map("completed_at")
  userId      String      @map("user_id")
  agentId     String?     @map("agent_id")
  clientId    String?     @map("client_id")
  dealId      String?     @map("deal_id")
  branch      String      @default("Harare")
  tags        String[]     @default([])
  metadata    Json?       @map("metadata")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@index([userId])
  @@index([agentId])
  @@index([status])
  @@index([dueDate])
  @@index([branch])
  @@index([createdAt(sort: Desc)])
  @@map("tasks")
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

/// *
///  * EventLog
///  * Tracks system events for notifications and audit purposes
///  * Used for notification generation and audit trails
model EventLog {
  id          String   @id @default(cuid())
  eventType   String   @map("event_type")
  entityType  String   @map("entity_type")
  entityId    String   @map("entity_id")
  userId      String?  @map("user_id")
  userRole    String?  @map("user_role")
  branch      String   @default("Harare")
  metadata    Json?
  severity    String   @default("INFO")
  processed   Boolean  @default(false)
  processedAt DateTime? @map("processed_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([eventType])
  @@index([entityType, entityId])
  @@index([userId])
  @@index([branch])
  @@index([processed])
  @@index([createdAt(sort: Desc)])
  @@map("event_logs")
}

/// *
///  * BackupJob
///  * Tracks weekly backup generation jobs
///  * Ensures idempotency and provides audit trail
model BackupJob {
  id             String           @id @default(cuid())
  scopeType      BackupScopeType  @map("scope_type")
  scopeId        String           @map("scope_id")      // developer_email or "admin"
  weekStart      DateTime         @map("week_start")    // ISO 8601 week start (Monday)
  weekEnd        DateTime         @map("week_end")      // ISO 8601 week end (Sunday)
  weekLabel      String           @map("week_label")    // e.g., "2026-W06"
  status         BackupJobStatus  @default(PENDING)
  artifactUrl    String?          @map("artifact_url")  // UploadThing URL
  artifactKey    String?          @map("artifact_key")  // UploadThing key for deletion
  fileSize       BigInt?          @map("file_size")     // bytes
  errorMessage   String?          @map("error_message") @db.Text
  startedAt      DateTime?        @map("started_at")
  completedAt    DateTime?        @map("completed_at")
  emailSent      Boolean          @default(false) @map("email_sent")
  emailSentAt    DateTime?        @map("email_sent_at")
  emailError     String?          @map("email_error") @db.Text
  retriesCount   Int              @default(0) @map("retries_count")
  lastRetryAt    DateTime?        @map("last_retry_at")
  metadata       Json?            // Store CSV row counts, file list, etc.
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  downloads      BackupDownload[]

  @@unique([scopeType, scopeId, weekStart])  // Idempotency: one backup per scope per week
  @@index([scopeType, scopeId])
  @@index([weekStart])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("backup_jobs")
}

/// *
///  * BackupDownload
///  * Tracks backup downloads for audit purposes
///  * Monitors access patterns and compliance
model BackupDownload {
  id          String   @id @default(cuid())
  backupJobId String   @map("backup_job_id")
  userId      String   @map("user_id")
  userEmail   String   @map("user_email")
  userRole    String   @map("user_role")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent") @db.Text
  downloadedAt DateTime @default(now()) @map("downloaded_at")

  backupJob    BackupJob @relation(fields: [backupJobId], references: [id], onDelete: Cascade)

  @@index([backupJobId])
  @@index([userId])
  @@index([downloadedAt(sort: Desc)])
  @@map("backup_downloads")
}

enum BackupScopeType {
  DEVELOPER
  ADMIN
}

enum BackupJobStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

/// *
///  * Contract Document Version
///  * Stores generated contract documents (DOCX, HTML, PDF) for versioning
///  * Enables download of original format documents
model ContractDocumentVersion {
  id            String   @id @default(cuid())
  contractId    String   @map("contract_id")
  templateId    String   @map("template_id")
  version       Int
  documentType  String   @map("document_type")  // 'html' | 'docx' | 'pdf'
  storageKey    String   @map("storage_key")    // UploadThing key
  storageUrl    String   @map("storage_url")    // UploadThing URL
  fileSize      Int?     @map("file_size")
  checksum      String?                          // SHA-256 hash
  generatedAt   DateTime @default(now()) @map("generated_at")
  generatedBy   String?  @map("generated_by")
  
  contract GeneratedContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  template ContractTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([contractId, version, documentType])
  @@index([contractId])
  @@index([templateId])
  @@map("contract_document_versions")
}

// ═══════════════════════════════════════════════════════════════════════════
// NEW UNIFIED LEDGER SYSTEM (2026 Refactor)
