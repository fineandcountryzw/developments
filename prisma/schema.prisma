model Notification {
  id              String           @id @default(cuid())
  type            NotificationType
  severity        SeverityLevel    @default(INFO)
  title           String
  message         String
  
  // Actor tracking
  actorUserId     String?          @map("actor_user_id")
  actorRole       UserRole?        @map("actor_role")
  
  // Recipient
  recipientUserId String           @map("recipient_user_id")
  recipientRole   UserRole?        @map("recipient_role")
  
  // Entity reference
  entityType      EntityType       @map("entity_type")
  entityId        String           @map("entity_id")
  developmentId   String?          @map("development_id")
  
  // Metadata
  metadata        Json?
  
  // Read tracking
  isRead          Boolean          @default(false) @map("is_read")
  readAt          DateTime?        @map("read_at")
  
  // Timestamps
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  
  // Relations
  recipient       User             @relation("ReceivedNotifications", fields: [recipientUserId], references: [id], onDelete: Cascade)
  actor           User?            @relation("ActorNotifications", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([recipientUserId, isRead, createdAt])
  @@index([entityType, entityId])
  @@index([developmentId])
  @@index([type, createdAt])
  @@map("notifications")
}

