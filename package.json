{
  "name": "fine-and-country-zimbabwe-erp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev -p 6060",
    "build": "prisma generate && next build",
    "typecheck": "tsc --noEmit",
    "start": "next start",
    "lint": "next lint",
    "test": "jest --config jest.config.cjs",
    "test:e2e": "jest --selectProjects e2e --config jest.config.cjs",
    "test:watch": "jest --watch --config jest.config.cjs",
    "test:coverage": "jest --coverage --config jest.config.cjs",
    "test:ci": "jest --ci --coverage --maxWorkers=2 --config jest.config.cjs",
    "db:push": "prisma db push --config prisma/prisma.config.ts",
    "db:verify": "tsx scripts/verify-schema.ts",
    "db:seed": "tsx scripts/seed-demo-data.ts",
    "db:reset": "prisma db push --force-reset --config prisma/prisma.config.ts && npm run db:seed",
    "validate-env": "node scripts/validate-env.js",
    "phase3:init": "npm run validate-env && npm run db:push"
  },
