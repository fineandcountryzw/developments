# Environment Variables for Fine & Country Zimbabwe ERP

# Database Connection (Neon PostgreSQL) - BACKEND ONLY
DATABASE_URL="postgresql://user:password@host.neon.tech/database?sslmode=require"

# Neon Auth Configuration - BACKEND ONLY
NEXT_PUBLIC_NEON_AUTH_URL="https://auth.neon.tech/YOUR_PROJECT_ID"

# Vite-prefixed environment variables for CLIENT-SIDE access
VITE_NEON_AUTH_URL="https://auth.neon.tech/YOUR_PROJECT_ID"

# NextAuth Configuration
NEXTAUTH_SECRET="your-nextauth-secret-here-minimum-32-characters"

# Cron Job Security
CRON_SECRET="your-secure-random-secret-here"

# UploadThing Configuration
UPLOADTHING_SECRET="your-uploadthing-secret"
UPLOADTHING_APP_ID="your-uploadthing-app-id"

# Resend Email Service
RESEND_API_KEY="re_your_resend_api_key"
AUTH_EMAIL_FROM="noreply@fineandcountryerp.com"

# Sentry Error Tracking
SENTRY_DSN="your-sentry-dsn-here"
NEXT_PUBLIC_SENTRY_DSN="your-sentry-dsn-here"
SENTRY_RELEASE="fine-and-country-erp@0.0.0"
NEXT_PUBLIC_SENTRY_RELEASE="fine-and-country-erp@0.0.0"

# CORS Configuration - Comma-separated list of allowed origins
ALLOWED_ORIGINS="http://localhost:6060,https://yourdomain.com,https://www.yourdomain.com"

# DocuSeal E-Signature Integration
DOCUSEAL_API_KEY="your-docuseal-api-key"
DOCUSEAL_BASE_URL="https://api.docuseal.co"
DOCUSEAL_WEBHOOK_SECRET="your-webhook-secret"
ENABLE_DOCUSEAL="true"

# ========================================================================
# MAINTENANCE MODE - Coming Soon Page with Password Protection
# ========================================================================

# Enable/Disable Maintenance Mode
# Set to "true" to show Coming Soon page and block all routes (except unlock)
# Set to "false" to allow normal ERP access (feature disabled)
ERP_MAINTENANCE_MODE="false"

# Password required to unlock the ERP during maintenance mode
# SECURITY: Keep this secret and change after maintenance period
# Only used when ERP_MAINTENANCE_MODE="true"
ERP_ACCESS_PASSWORD="your-secure-password-here"